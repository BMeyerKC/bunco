---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Bunco Debug">
  <div style="padding:20px; max-width:960px; margin:0 auto;">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
      <h3 style="margin:0;color:var(--fg);">Event Log</h3>
      <span id="debug-code" style="font-family:monospace;font-size:1.1rem;color:var(--purple-light);letter-spacing:0.15em;"></span>
    </div>
    <div id="event-timeline" style="overflow-y:auto;max-height:calc(100vh - 100px);">
      <p style="color:var(--very-muted);">Loading…</p>
    </div>
  </div>
  <script>
    import '../js/debug-controller.js';
  </script>
</Layout>
